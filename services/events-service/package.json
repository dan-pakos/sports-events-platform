{
  "name": "@sep/events-service",
  "version": "1.0.0",
  "description": "Events Service",
  "type": "module",
  "main": "dist/index.js",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:docker": "nodemon -L --inspect=0.0.0.0 src/index.ts",
    "build": "tsup src/index.ts --format esm --clean --minify --dts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.4",
  "dependencies": {
    "@fastify/env": "^6.0.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sep/fastify-logger": "workspace:*",
    "@sep/proto": "workspace:*",
    "fastify": "^5.8.5",
    "pg": "^8.20.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@sep/contracts": "workspace:*",
    "@sep/eslint-config": "workspace:*",
    "@sep/tsconfig": "workspace:*",
    "@types/node": "^20.19.39",
    "eslint": "^10.2.1",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  }
}
